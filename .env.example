# ===========================================
# CryptoBot Configuration
# ===========================================

# Bybit API Credentials
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# Trading Configuration
TRADING_SYMBOLS=["BTCUSDT","ETHUSDT"]
ACTIVE_STRATEGIES=["GoldenCrossImproved","BollingerRSIImproved"]

# System Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Risk Management
MAX_DAILY_LOSS=50.0
MAX_POSITION_SIZE=100.0
MAX_LEVERAGE=3.0
SIMULATION_MODE=true
INITIAL_CAPITAL=10000.0

# ===========================================
# AI Provider Configuration
# ===========================================

# Select AI Provider: deepseek, alibaba, openai
AI_PROVIDER=alibaba

# DeepSeek Configuration (default)
LLM_API_KEY=your_deepseek_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ===========================================
# Alibaba Model Studio Configuration
# ===========================================
ALIBABA_API_KEY=sk-sp-998b1971f6c5434c949b6f6cc21c6db7
ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1
ALIBABA_MODEL=qwen3.5-plus

# Available Models (comma-separated):
# qwen3.5-plus - General purpose, 1M context, multilingual
# qwen3-coder-plus - Code analysis, 1M context
# qwen3-coder-next - Latest coding model, 1M context
# qwen3-max-2026-01-23 - High accuracy, 262K context
# kimi-k2.5 - Long context, 262K context, reasoning
# MiniMax-M2.5 - Fast, 196K context
# glm-5 - Balanced, 202K context
# glm-4.7 - Cost-effective, 202K context
ALIBABA_AVAILABLE_MODELS=qwen3.5-plus,qwen3-coder-plus,kimi-k2.5,glm-5

# ===========================================
# Machine Learning
# ===========================================
ENABLE_ML=true

# ===========================================
# Database
# ===========================================
DATABASE_URL=sqlite:///storage/data.db

# ===========================================
# Telegram Notifications
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===========================================
# On-chain Analysis
# ===========================================
COINGECKO_API_KEY=your_coingecko_key
MESSARI_API_KEY=your_messari_key
ENABLE_ONCHAIN_FILTER=true
